#!/bin/bash

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

echo -e "${BLUE}========================================${NC}"
echo -e "${BLUE}   Query SN for Device IP Address${NC}"
echo -e "${BLUE}========================================${NC}"
echo ""

# Check if binary exists
if [ ! -f "upgrade-linux-amd64" ]; then
    echo -e "${RED}Error: upgrade-linux-amd64 not found${NC}"
    exit 1
fi

# Check if dlv exists
if ! command -v dlv &> /dev/null; then
    echo -e "${RED}Error: dlv (delve) not installed${NC}"
    echo "Install with: sudo apt install delve"
    exit 1
fi

# Get IP from user
read -p "Enter IP address: " TARGET_IP

# Validate IP
if ! echo "$TARGET_IP" | grep -qE '^[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}$'; then
    echo -e "${RED}Error: Invalid IP format${NC}"
    exit 1
fi

# Create dummy file
mkdir -p ./tmp
touch ./tmp/fake.tar.gz

echo -e "${GREEN}Querying SN for IP: $TARGET_IP${NC}"
echo -e "${YELLOW}Starting dlv...${NC}"
echo ""

# Run dlv with the allow flag
echo -e "break main.main\ncontinue\nprint main.ipToSN[\"$TARGET_IP\"]\nquit" | \
    dlv --allow-non-terminal-interactive=true exec ./upgrade-linux-amd64 -- -remote ./tmp/fake.tar.gz 2>&1

# Check result
if [ $? -eq 0 ]; then
    echo ""
    echo -e "${GREEN}========================================${NC}"
    echo -e "${GREEN}Query completed${NC}"
    echo -e "${GREEN}========================================${NC}"
else
    echo ""
    echo -e "${RED}Error: dlv command failed${NC}"
    echo -e "${YELLOW}Try running without the script to see detailed errors:${NC}"
    echo "dlv exec ./upgrade-linux-amd64 -- -remote ./tmp/fake.tar.gz"
fi
